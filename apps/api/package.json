{
  "name": "@teammem/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "pnpm --filter @teammem/shared build && tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:api": "vitest run --config vitest.integration.config.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "smoke": "tsx scripts/smoke.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@supabase/supabase-js": "^2.103.0",
    "@teammem/shared": "workspace:*",
    "bcrypt": "^5.1.1",
    "dotenv": "^17.4.2",
    "hono": "^4.6.14",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1",
    "pgvector": "^0.2.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
