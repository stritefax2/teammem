# Supabase (get these from your Supabase project dashboard → Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# Database (get from Supabase dashboard → Settings → Database → Connection string)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# OpenAI (optional — enables semantic search via embeddings)
OPENAI_API_KEY=sk-your-openai-key

# Connector encryption (required for Postgres/Sheets connectors)
# Generate with: openssl rand -base64 32
CONNECTOR_ENCRYPTION_KEY=

# Sync interval for connected collections (milliseconds, default 15 min)
# SYNC_INTERVAL_MS=900000

# Max rows pulled per sync per table (default 10000)
# CONNECTOR_MAX_ROWS=10000

# External-scheduler secret (required on serverless / Vercel).
# Allows Vercel Cron or an external cron service to POST
# /api/v1/admin/sync-due with header `x-cron-secret: <this value>`.
# Generate with: openssl rand -hex 32
CRON_SECRET=

# CORS allowlist — comma-separated origins that may call the API from a
# browser. Leave blank in dev (localhost is always allowed). REQUIRED in
# production or all browser requests will be rejected.
# Example: ALLOWED_ORIGINS=https://app.rhona.dev,https://staging.rhona.dev
ALLOWED_ORIGINS=

# Public web app URL. Used as the redirect target in invite emails so users
# click through to your production web app, not localhost. REQUIRED in
# production for the invite flow to land users on the right domain.
# Example: WEB_URL=https://app.rhona.dev
WEB_URL=

# Server
PORT=3001
